{
  "entities": {
    "User": {
      "title": "User",
      "description": "A developer or admin in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "developer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A Power Apps project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "createdBy"]
    },
    "Task": {
      "title": "Task",
      "description": "A development task.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "projectId": { "type": "string" },
        "assigneeId": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed", "testing"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "projectId", "status", "createdBy"]
    },
    "Deployment": {
      "title": "Deployment",
      "description": "A deployment of tasks.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "version": { "type": "string" },
        "powerAppsVersion": { "type": "string" },
        "environment": { "type": "string", "enum": ["dev", "stage", "prod"] },
        "taskIds": { "type": "array", "items": { "type": "string" } },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["projectId", "version", "powerAppsVersion", "environment", "taskIds", "createdBy"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores projects."
    },
    "tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores tasks."
    },
    "deployments/{deploymentId}": {
      "schema": { "$ref": "#/entities/Deployment" },
      "description": "Stores deployments."
    }
  }
}
